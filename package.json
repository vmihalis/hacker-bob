{
  "name": "hacker-bob",
  "version": "1.1.0",
  "description": "Portable autonomous bug bounty hunting MCP framework with host adapters",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmihalis/hacker-bob.git"
  },
  "bugs": {
    "url": "https://github.com/vmihalis/hacker-bob/issues"
  },
  "homepage": "https://github.com/vmihalis/hacker-bob#readme",
  "bin": {
    "hacker-bob": "bin/hacker-bob.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    ".hacker-bob/**/*",
    ".claude/**/*",
    "adapters/**/*",
    "bin/**/*",
    "docs/**/*.md",
    "docs/hacker-bob.png",
    "mcp/**/*",
    "prompts/**/*",
    "scripts/**/*",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "DISCLAIMER.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "install.sh"
  ],
  "scripts": {
    "check:syntax": "find bin adapters scripts mcp .claude/hooks -type f -name '*.js' -print0 | xargs -0 -n1 node --check",
    "check:roles": "node scripts/generate-claude-roles.js --check",
    "check:codex-skills": "node scripts/generate-codex-skills.js --check",
    "check:agent-tools": "node scripts/generate-agent-tools.js --check",
    "check:skill": "node scripts/generate-bountyagent-skill.js --check",
    "test:mcp": "node --test test/mcp-server.test.js",
    "test:prompts": "npm run check:roles && npm run check:codex-skills && npm run check:agent-tools && npm run check:skill && node --test test/prompt-contracts.test.js",
    "test:install": "node --test test/install-smoke.test.js",
    "test:update": "node --test test/update-check.test.js",
    "test:cli": "node --test test/cli.test.js",
    "test:package": "node --test test/package.test.js",
    "test:hooks": "python3 test/test-write-guard.py",
    "test": "npm run check:syntax && npm run test:mcp && npm run test:prompts && npm run test:install && npm run test:update && npm run test:cli && npm run test:package && npm run test:hooks",
    "release:check": "node scripts/release-check.js",
    "release:check:registry": "node scripts/release-check.js --registry",
    "install-browser": "npx patchright install chromium"
  },
  "optionalDependencies": {
    "patchright": "^1.59.4"
  }
}
